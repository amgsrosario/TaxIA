##
## KnowledgeFlow — variáveis de ambiente
## Copia este ficheiro para .env e preenche com os valores reais.
## NUNCA versionas o ficheiro .env.
##

# ── Base de dados ─────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:15433/knowledgeflow
SPRING_DATASOURCE_USERNAME=knowledgeflow
SPRING_DATASOURCE_PASSWORD=knowledgeflow

# ── Servidor ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── JWT ───────────────────────────────────────────────────────────────────────
KNOWLEDGEFLOW_JWT_ISSUER=knowledgeflow-backend
KNOWLEDGEFLOW_JWT_SECRET=change-this-development-secret-change-this-development-secret
KNOWLEDGEFLOW_JWT_ACCESS_TOKEN_TTL_MINUTES=60

# ── IA — provider principal ───────────────────────────────────────────────────
# Valores possíveis: anthropic | openai | stub
AI_PRIMARY_PROVIDER=anthropic

# ── IA — Anthropic ────────────────────────────────────────────────────────────
# Obter a chave em: https://console.anthropic.com/settings/keys
ANTHROPIC_ENABLED=true
ANTHROPIC_API_KEY=sk-ant-SUBSTITUI-ESTA-CHAVE
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024

# ── IA — OpenAI ───────────────────────────────────────────────────────────────
# Obter a chave em: https://platform.openai.com/api-keys
OPENAI_ENABLED=false
OPENAI_API_KEY=sk-proj-SUBSTITUI-ESTA-CHAVE
OPENAI_MODEL=
OPENAI_MAX_TOKENS=1024

# ── IA — Stub (sem chamadas externas, para desenvolvimento local) ─────────────
STUB_AI_ENABLED=false

# ── RAG — serviço de embeddings ───────────────────────────────────────────────
EMBEDDINGS_SERVICE_URL=http://localhost:8000
RAG_TOP_K=5
